<!-- views/users/follow-list.ejs -->
<!-- Reused for both followers and following pages -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Vibe</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="container mt-4">
    <a href="/users/<%= profileUser.username %>" class="back-link">← @<%= profileUser.username %></a>
    <h1 class="page-title"><%= listTitle %></h1>

    <% if (users.length === 0) { %>
      <div class="empty-state">
        <p>No <%= listTitle.toLowerCase() %> yet.</p>
      </div>
    <% } else { %>
      <div class="user-list">
        <% users.forEach(user => { %>
          <a href="/users/<%= user.username %>" class="user-list-item">
            <img src="<%= user.avatar %>" alt="" class="user-list-avatar" />
            <div class="user-list-info">
              <span class="user-list-name"><%= user.name %></span>
              <span class="user-list-username">@<%= user.username %></span>
              <% if (user.bio) { %>
                <span class="user-list-bio"><%= user.bio %></span>
              <% } %>
            </div>
            <span class="chevron">→</span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
